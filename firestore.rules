rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Security rules for collections
    match /listings/{document} {
      allow read, write: if true;
    }
    match /registered_buyers/{document} {
      allow read, write: if true;
    }
    match /buyer_leads/{document} {
      allow read, write: if true;
    }
    match /system_config/{document} {
      allow read, write: if true;
    }
  }
}
